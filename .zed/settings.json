{
  "context_servers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      },
      "source": "custom"
    },
    "exa": {
      "url": "https://mcp.exa.ai/mcp",
      "source": "custom"
    },
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      },
      "source": "custom"
    },
    "skillz": {
      "command": "uvx",
      "args": [
        "skillz@latest",
        "/Users/gg/Work/Kalvi/kalvi-library-template/.skillz"
      ],
      "source": "custom"
    }
  }
}