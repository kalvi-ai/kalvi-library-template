{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "enable git hooks",
      "type": "shell",
      "command": "uv run pre-commit install && uv run pre-commit install --hook-type commit-msg",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "pytest",
      "type": "shell",
      "command": "uv run pytest",
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "ruff check",
      "type": "shell",
      "command": "uv run ruff check src tests scripts",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "ruff format",
      "type": "shell",
      "command": "uv run ruff format src tests scripts",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "ruff format (check)",
      "type": "shell",
      "command": "uv run ruff format --check src tests scripts",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "pylint",
      "type": "shell",
      "command": "uv run pylint src/kalvi_library_template scripts",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "mypy",
      "type": "shell",
      "command": "uv run mypy src/kalvi_library_template scripts",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "pre-commit",
      "type": "shell",
      "command": "uv run pre-commit run --all-files",
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "quality checks",
      "dependsOrder": "sequence",
      "dependsOn": [
        "pytest",
        "ruff check",
        "ruff format (check)",
        "pylint",
        "mypy",
        "pre-commit"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
